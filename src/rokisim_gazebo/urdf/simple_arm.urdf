<?xml version="1.0"?>
<robot name="fairino_6dof">

  <link name="world"/>
  <joint name="fixed_to_world" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <material name="dark_grey"><color rgba="0.15 0.15 0.15 1"/></material>
  <material name="fairino_orange"><color rgba="1.0 0.45 0.05 1"/></material>
  <material name="light_grey"><color rgba="0.75 0.75 0.75 1"/></material>

  <link name="base_link">
    <visual><origin xyz="0 0 0.04"/><geometry><box size="0.22 0.22 0.08"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 0.04"/><geometry><box size="0.22 0.22 0.08"/></geometry></collision>
    <inertial><mass value="8.0"/><origin xyz="0 0 0.04"/><inertia ixx="0.03" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.03"/></inertial>
  </link>

  <link name="link1">
    <visual><origin xyz="0 0 0.11"/><geometry><box size="0.14 0.14 0.22"/></geometry><material name="fairino_orange"/></visual>
    <collision><origin xyz="0 0 0.11"/><geometry><box size="0.14 0.14 0.22"/></geometry></collision>
    <inertial><mass value="4.5"/><origin xyz="0 0 0.11"/><inertia ixx="0.015" ixy="0" ixz="0" iyy="0.015" iyz="0" izz="0.015"/></inertial>
  </link>
  <joint name="joint1" type="revolute">
    <parent link="base_link"/><child link="link1"/><origin xyz="0 0 0.05" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-2.8" upper="2.8" effort="180" velocity="1.5"/>
  </joint>

  <link name="link2">
    <visual><origin xyz="0 0 0.21"/><geometry><box size="0.12 0.12 0.42"/></geometry><material name="light_grey"/></visual>
    <collision><origin xyz="0 0 0.21"/><geometry><box size="0.12 0.12 0.42"/></geometry></collision>
    <inertial><mass value="5.5"/><origin xyz="0 0 0.21"/><inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/></inertial>
  </link>
  <joint name="joint2" type="revolute">
    <parent link="link1"/><child link="link2"/><origin xyz="0 0 0.2" rpy="0 1.5708 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="180" velocity="1.5"/>
  </joint>

  <link name="link3">
    <visual><origin xyz="0 0 0.16"/><geometry><box size="0.10 0.10 0.32"/></geometry><material name="fairino_orange"/></visual>
    <collision><origin xyz="0 0 0.16"/><geometry><box size="0.10 0.10 0.32"/></geometry></collision>
    <inertial><mass value="3.2"/><origin xyz="0 0 0.16"/><inertia ixx="0.012" ixy="0" ixz="0" iyy="0.012" iyz="0" izz="0.012"/></inertial>
  </link>
  <joint name="joint3" type="revolute">
    <parent link="link2"/><child link="link3"/><origin xyz="0 0 0.4" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.45" upper="2.45" effort="150" velocity="2.0"/>
  </joint>

  <link name="link4">
    <visual><origin xyz="0 0 0.06"/><geometry><box size="0.08 0.08 0.12"/></geometry><material name="light_grey"/></visual>
    <collision><origin xyz="0 0 0.06"/><geometry><box size="0.08 0.08 0.12"/></geometry></collision>
    <inertial><mass value="1.2"/><origin xyz="0 0 0.06"/><inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/></inertial>
  </link>
  <joint name="joint4" type="revolute">
    <parent link="link3"/><child link="link4"/><origin xyz="0 0 0.3" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="80" velocity="2.5"/>
  </joint>

  <link name="link5">
    <visual><origin xyz="0 0 0.06"/><geometry><box size="0.07 0.07 0.12"/></geometry><material name="fairino_orange"/></visual>
    <collision><origin xyz="0 0 0.06"/><geometry><box size="0.07 0.07 0.12"/></geometry></collision>
    <inertial><mass value="1.0"/><origin xyz="0 0 0.06"/><inertia ixx="0.0015" ixy="0" ixz="0" iyy="0.0015" iyz="0" izz="0.0015"/></inertial>
  </link>
  <joint name="joint5" type="revolute">
    <parent link="link4"/><child link="link5"/><origin xyz="0 0 0.1" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="80" velocity="3.15"/>
  </joint>

  <link name="link6">
    <visual><origin xyz="0 0 0.03"/><geometry><box size="0.06 0.06 0.06"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 0.03"/><geometry><box size="0.06 0.06 0.06"/></geometry></collision>
    <inertial><mass value="0.6"/><origin xyz="0 0 0.03"/><inertia ixx="0.0012" ixy="0" ixz="0" iyy="0.0012" iyz="0" izz="0.0012"/></inertial>
  </link>
  <joint name="joint6" type="revolute">
    <parent link="link5"/><child link="link6"/><origin xyz="0 0 0.1" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="80" velocity="3.15"/>
  </joint>

  <link name="gripper_base">
    <visual><origin xyz="0 0 0.02"/><geometry><box size="0.16 0.05 0.04"/></geometry><material name="dark_grey"/></visual>
    <collision><origin xyz="0 0 0.02"/><geometry><box size="0.16 0.05 0.04"/></geometry></collision>
    <inertial><mass value="0.25"/><inertia ixx="0.00025" ixy="0" ixz="0" iyy="0.00025" iyz="0" izz="0.00025"/></inertial>
  </link>
  <joint name="gripper_base_joint" type="fixed">
    <parent link="link6"/><child link="gripper_base"/><origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <link name="finger_right">
    <visual><origin xyz="0 0 0.05"/><geometry><box size="0.018 0.03 0.09"/></geometry><material name="fairino_orange"/></visual>
    <collision><origin xyz="0 0 0.05"/><geometry><box size="0.018 0.03 0.09"/></geometry></collision>
    <inertial><mass value="0.06"/><inertia ixx="0.00006" ixy="0" ixz="0" iyy="0.00006" iyz="0" izz="0.00006"/></inertial>
  </link>
  <joint name="gripper_right_joint" type="fixed"> 
    <parent link="gripper_base"/><child link="finger_right"/>
    <origin xyz="-0.075 0 0.04" rpy="0 0 0"/>
  </joint>

  <link name="finger_left">
    <visual><origin xyz="0 0 0.05"/><geometry><box size="0.018 0.03 0.09"/></geometry><material name="fairino_orange"/></visual>
    <collision><origin xyz="0 0 0.05"/><geometry><box size="0.018 0.03 0.09"/></geometry></collision>
    <inertial><mass value="0.06"/><inertia ixx="0.00006" ixy="0" ixz="0" iyy="0.00006" iyz="0" izz="0.00006"/></inertial>
  </link>
  <joint name="gripper_joint" type="prismatic"> <parent link="gripper_base"/><child link="finger_left"/>
    <origin xyz="0.075 0 0.04" rpy="0 0 0"/><axis xyz="-1 0 0"/> 
    <limit lower="0.0" upper="0.125" effort="100" velocity="0.5"/>
  </joint>

  <link name="camera_pivot"><inertial><mass value="0.01"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <joint name="camera_pan_joint" type="continuous"><parent link="world"/><child link="camera_pivot"/><origin xyz="0 0 0" rpy="0 0 0"/><axis xyz="0 0 1"/></joint>
  
  <link name="camera_link">
    <visual><geometry><box size="0.05 0.05 0.05"/></geometry><material name="dark_grey"/></visual>
    <inertial><mass value="0.1"/><origin xyz="0 0 0"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="camera_mount_joint" type="fixed"><parent link="camera_pivot"/><child link="camera_link"/><origin xyz="1.5 0 1.2" rpy="0 0.5 3.14159"/></joint>

  <gazebo reference="camera_link">
    <sensor type="camera" name="kamera_sensor">
      <always_on>true</always_on><update_rate>30.0</update_rate>
      <camera name="kamera"><horizontal_fov>1.047</horizontal_fov><image><width>640</width><height>480</height><format>R8G8B8</format></image><clip><near>0.1</near><far>100</far></clip></camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so"><ros><namespace>kamera</namespace></ros><frame_name>camera_link</frame_name></plugin>
    </sensor>
  </gazebo>

  <ros2_control name="GazeboSystem" type="system">
    <hardware><plugin>gazebo_ros2_control/GazeboSystem</plugin></hardware>
    <joint name="joint1"><command_interface name="position"/><state_interface name="position"/></joint>
    <joint name="joint2"><command_interface name="position"/><state_interface name="position"/></joint>
    <joint name="joint3"><command_interface name="position"/><state_interface name="position"/></joint>
    <joint name="joint4"><command_interface name="position"/><state_interface name="position"/></joint>
    <joint name="joint5"><command_interface name="position"/><state_interface name="position"/></joint>
    <joint name="joint6"><command_interface name="position"/><state_interface name="position"/></joint>
    <joint name="gripper_joint"><command_interface name="position"/><state_interface name="position"/></joint>
    <joint name="camera_pan_joint"><command_interface name="position"/><state_interface name="position"/></joint>
  </ros2_control>

  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>/home/main/rokisim_ws/src/rokisim_gazebo/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="finger_left">
    <mu1>1000.0</mu1><mu2>1000.0</mu2><material>Gazebo/Orange</material>
  </gazebo>
  <gazebo reference="finger_right">
    <mu1>1000.0</mu1><mu2>1000.0</mu2><material>Gazebo/Orange</material>
  </gazebo>

  <gazebo reference="base_link"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="link1"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="link2"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="link3"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="link4"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="link5"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="link6"><material>Gazebo/DarkGrey</material></gazebo>

</robot>
